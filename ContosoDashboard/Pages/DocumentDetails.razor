@page "/documents/{DocumentId:int}"
@using ContosoDashboard.Models
@using ContosoDashboard.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject IUserService UserService
@inject IProjectService ProjectService
@inject ITaskService TaskService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Document Details - ContosoDashboard</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1>Document Details</h1>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert alert-success">@Message</div>
    }

    @if (Document == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-body">
                        <h4>@Document.Title</h4>
                        <p class="text-muted mb-1">@Document.Category</p>
                        <p>@Document.Description</p>
                        <dl class="row">
                            <dt class="col-sm-4">Uploaded By</dt>
                            <dd class="col-sm-8">@Document.Uploader.DisplayName</dd>
                            <dt class="col-sm-4">Uploaded</dt>
                            <dd class="col-sm-8">@Document.UploadDate.ToString("MMM dd, yyyy")</dd>
                            <dt class="col-sm-4">File</dt>
                            <dd class="col-sm-8">@Document.OriginalFileName (@(Document.FileSize / 1024) KB)</dd>
                            <dt class="col-sm-4">Project</dt>
                            <dd class="col-sm-8">@(Document.Project?.Name ?? "Personal")</dd>
                        </dl>
                        <div class="d-flex gap-2">
                            <a class="btn btn-primary" href="@Document.DownloadUrl" target="_blank">Download</a>
                            @if (Document.IsPreviewable)
                            {
                                <a class="btn btn-outline-secondary" href="@Document.DownloadUrl" target="_blank">Preview</a>
                            }
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Share Document</h5>
                    </div>
                    <div class="card-body">
                        <div class="row gy-3">
                            <div class="col-md-6">
                                <label class="form-label">User</label>
                                <select class="form-select" @bind="SelectedUserId">
                                    <option value="0">-- Select user --</option>
                                    @foreach (var user in Users)
                                    {
                                        <option value="@user.UserId">@user.DisplayName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Project</label>
                                <select class="form-select" @bind="SelectedProjectId">
                                    <option value="0">-- Select project --</option>
                                    @foreach (var project in Projects)
                                    {
                                        <option value="@project.ProjectId">@project.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Role / Notes</label>
                                <input class="form-control" @bind="ShareRole" placeholder="Optional role or note" />
                            </div>
                            <div class="col-12 text-end">
                                <button class="btn btn-primary" @onclick="ShareDocument">Share</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Attach to Task</h5>
                    </div>
                    <div class="card-body">
                        <div class="row gy-3">
                            <div class="col-md-8">
                                <label class="form-label">Task</label>
                                <select class="form-select" @bind="SelectedTaskId">
                                    <option value="0">-- Select task --</option>
                                    @foreach (var task in Tasks)
                                    {
                                        <option value="@task.TaskId">@task.Title</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 align-self-end text-end">
                                <button class="btn btn-primary" @onclick="AttachToTask">Attach Document</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int DocumentId { get; set; }

    private Document? Document;
    private int currentUserId = 0;
    private List<User> Users = new();
    private List<Project> Projects = new();
    private List<TaskItem> Tasks = new();
    private int SelectedUserId;
    private int SelectedProjectId;
    private int SelectedTaskId;
    private string ShareRole = string.Empty;
    private string Message = string.Empty;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
        {
            currentUserId = userId;
        }

        if (currentUserId > 0)
        {
            Document = await DocumentService.GetDocumentByIdAsync(DocumentId, currentUserId);
            if (Document == null)
            {
                ErrorMessage = "Document not found or you do not have access.";
                return;
            }

            Users = await UserService.GetAllUsersAsync();
            Projects = await ProjectService.GetUserProjectsAsync(currentUserId);
            Tasks = await TaskService.GetUserTasksAsync(currentUserId);
        }
    }

    private async Task ShareDocument()
    {
        if (Document == null)
        {
            return;
        }

        var request = new DocumentShareRequest
        {
            ProjectId = SelectedProjectId == 0 ? null : SelectedProjectId,
            Role = string.IsNullOrWhiteSpace(ShareRole) ? null : ShareRole
        };

        if (SelectedUserId > 0)
        {
            request.UserIds.Add(SelectedUserId);
        }

        if (!request.UserIds.Any() && !request.ProjectId.HasValue)
        {
            ErrorMessage = "Select a user or project before sharing.";
            return;
        }

        var success = await DocumentService.ShareDocumentAsync(Document.DocumentId, request, currentUserId);
        if (success)
        {
            Message = "Document shared successfully.";
            ErrorMessage = string.Empty;
        }
        else
        {
            ErrorMessage = "Unable to share document.";
            Message = string.Empty;
        }
    }

    private async Task AttachToTask()
    {
        if (Document == null || SelectedTaskId == 0)
        {
            ErrorMessage = "Select a task to attach the document.";
            Message = string.Empty;
            return;
        }

        var success = await DocumentService.AttachDocumentToTaskAsync(Document.DocumentId, SelectedTaskId, currentUserId);
        if (success)
        {
            Message = "Document attached to task successfully.";
            ErrorMessage = string.Empty;
        }
        else
        {
            ErrorMessage = "Unable to attach document to task.";
            Message = string.Empty;
        }
    }
}
